    super({
      baseURL: baseURL,
      apiKey: options.apiKey ?? readEnv('PETSTORE_API_KEY') ?? '',
      maxRetries: options.maxRetries ?? 2,
      timeout: options.timeout ?? 30000,
      ...options,
    });
